# Anthropic — enables Claude-powered provenance extraction from museum prose.
# Without this key (or when out of credits), deterministic fallback extraction is active.
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Europeana — adds 50M+ objects from 3,000+ European institutions to search results.
# Free instant key: https://apis.europeana.eu/api/apikey
EUROPEANA_API_KEY=

# GitHub fine-grained PAT (repo: nyahn01/provenance-tracker) with Issues: Read & write.
# Powers the in-app feedback form — /api/feedback files a labeled "feedback" issue.
# Absent → the form degrades to the email fallback (no error shown to the user).
# Create: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
